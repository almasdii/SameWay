## Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/taxi_system

## JWT
SECRET_KEY=change_me
ALGORITHM=HS256

## Redis (rate limit + token blocklist + celery broker/backend)
REDIS_URL=redis://localhost:6379/0

## Mail (optional). If MAIL_USERNAME is empty, mail is disabled.
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=noreply@example.com
MAIL_FROM_NAME=Taxi System
MAIL_PORT=587
MAIL_SERVER=smtp.gmail.com
MAIL_STARTTLS=True
MAIL_SSL_TLS=False
USE_CREDENTIALS=True
VALIDATE_CERTS=True